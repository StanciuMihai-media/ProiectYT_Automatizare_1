<project_root name="ai_shorts_studio">
    <!-- Fișierul care dirijează containerele -->
    <file name="docker-compose.yml" />
    
    <!-- Containerul 1: Logica și Generarea -->
    <directory name="orchestrator_python">
        <file name="Dockerfile" />
        <file name="requirements.txt" />
        <file name="main_loop.py" description="Scriptul CRON care declanșează fluxul" />
        <directory name="modules">
            <file name="claude_director.py" description="Prompting și generare script JSON" />
            <file name="voice_elevenlabs.py" description="Generare TTS" />
            <file name="whisper_sync.py" description="Extragere timestamps și tăiere pauze" />
            <file name="image_generator.py" description="Apel API pentru fundaluri unice" />
            <file name="youtube_uploader.py" description="Upload via API ca Draft" />
        </directory>
        <directory name="database">
            <file name="channels.db" description="Baza de date SQLite" />
        </directory>
    </directory>

    <!-- Containerul 2: Randarea Video -->
    <directory name="remotion_engine">
        <file name="Dockerfile" />
        <file name="package.json" />
        <file name="remotion.config.ts" />
        <directory name="src">
            <file name="Root.tsx" description="Înregistrarea compozițiilor video" />
            <file name="MainComposition.tsx" description="Șablonul vizual principal (stilul Pham)" />
            <directory name="components">
                <file name="DynamicSubtitle.tsx" description="Animațiile textului (Kinetic Typography)" />
                <file name="BackgroundManager.tsx" description="Gestionarea imaginilor și a tranzițiilor" />
            </directory>
        </directory>
    </directory>

    <!-- Folderul comun: Puntea dintre cele două containere -->
    <directory name="shared_workspace">
        <directory name="project_xyz_123">
            <file name="director_script.json" description="Scenariul și coordonatele de la Claude/Whisper" />
            <file name="voiceover.mp3" />
            <directory name="assets">
                <file name="bg_1.jpg" />
                <file name="bg_2.jpg" />
            </directory>
            <file name="final_render.mp4" description="Produsul final generat de Remotion" />
        </directory>
    </directory>
</project_root>
